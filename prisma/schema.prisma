// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model StockMaster {
  id              Int      @id @default(autoincrement())
  transactionDate DateTime
  location        String

  gsmCode      String
  gsmName      String
  categoryCode String
  articleName  String
  subcategoryCode String?
  subcategoryName String?
  category     Category @relation(fields: [categoryCode], references: [code], onDelete: Cascade)
  subcategory  Subcategory? @relation(fields: [subcategoryCode], references: [code], onDelete: Cascade)
  qty          Int
  description  String?
  carat        String?

  wastageYN     Boolean  @default(false)
  goldWeight    Decimal
  goldCost      Decimal
  wastageMg     Decimal   @default(0)
  wastage       Decimal
  labourCharges Decimal
  otherCosts    Decimal
  totalCost     Decimal
  remarks       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryCode])
  @@index([subcategoryCode])
}

model Goldsmith {
  code      String   @id
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  code      String   @id
  name      String
  subcategories Subcategory[]
  stock     StockMaster[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subcategory {
  code         String   @id
  name         String
  imageUrl     String?
  categoryCode String
  category     Category @relation(fields: [categoryCode], references: [code], onDelete: Cascade)
  stock        StockMaster[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model System {
  id                   Int     @id
  vatRate              Decimal
  nslRate              Decimal
  goldCostRatePer8g    Decimal
  wastageRateMgPer8g   Decimal
  updatedAt            DateTime @updatedAt

  @@map("system")
}
