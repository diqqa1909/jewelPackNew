// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model StockMaster {
  id              Int      @id @default(autoincrement())
  transactionDate DateTime
  location        String?

  gsmCode      String
  gsmName      String
  categoryCode String
  articleName  String
  subcategoryCode String
  subcategoryName String
  category     Category @relation(fields: [categoryCode], references: [code], onDelete: Restrict)
  subcategory  Subcategory @relation(fields: [subcategoryCode], references: [code], onDelete: Restrict)
  qty          Int
  description  String?
  carat        String?

  wastageYN     Boolean  @default(false)
  goldWeight    Decimal
  goldCost      Decimal
  wastageMg     Decimal   @default(0)
  wastage       Decimal
  labourCharges Decimal
  otherCosts    Decimal
  totalCost     Decimal
  // Balances (updated as items are sold)
  soldQty          Int     @default(0)
  balanceQty       Int
  soldGoldWeight   Decimal @default(0)
  balanceGoldWeight Decimal
  soldCost         Decimal @default(0)
  balanceCost      Decimal
  remarks       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryCode])
  @@index([subcategoryCode])

  sales Sale[]
}

model Goldsmith {
  code      String   @id
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Supplier {
  id        Int      @id @default(autoincrement())
  name      String
  contact   String?
  phone     String?
  email     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])

  purchases Purchase[]
}

model Category {
  code      String   @id
  name      String
  subcategories Subcategory[]
  stock     StockMaster[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subcategory {
  code         String   @id
  name         String
  imageUrl     String?
  categoryCode String
  category     Category @relation(fields: [categoryCode], references: [code], onDelete: Restrict)
  carat        String?
  stock        StockMaster[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model System {
  id                   Int     @id
  vatRate              Decimal
  nslRate              Decimal
  goldCostRatePer8g    Decimal
  wastageRateMgPer8g   Decimal
  updatedAt            DateTime @updatedAt

  @@map("system")
}

model Customer {
  id        Int      @id @default(autoincrement())
  accountNumber String? @unique
  name      String
  phone     String?
  email     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sales     SalesNTX[]
}

model Transaction {
  id              Int      @id @default(autoincrement())
  date            DateTime @db.Date
  source          String?
  account         String?
  memo            String?
  debit           Decimal  @default(0) @db.Decimal(12, 2)
  credit          Decimal  @default(0) @db.Decimal(12, 2)
  accountNumber   String?  @map("account_number")
  type            String?
  bankDebit       Decimal? @default(0) @map("bank_debit") @db.Decimal(12, 2)
  bankCredit      Decimal? @default(0) @map("bank_credit") @db.Decimal(12, 2)
  realizedDate    DateTime? @map("realized_date") @db.Date
  referenceNumber String?  @map("reference_number")
  remarks         String?
  bankCode        String?  @map("bank_code")
  recon           Boolean  @default(false)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([accountNumber])
  @@index([date])
  @@map("transactions")
}

model SalesNTX {
  id            Int      @id @default(autoincrement())
  saleNo        String   @unique
  transactionDate DateTime
  customerId    Int
  customer      Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)
  salesmanId    Int?
  salesman      Salesman? @relation(fields: [salesmanId], references: [id], onDelete: Restrict)

  totalItems    Int
  totalQty      Int
  totalGoldWeight Decimal
  totalCost     Decimal
  sellRatePer8g Decimal @default(0)
  sellSubTotal  Decimal @default(0)
  remarks       String?

  items         Sale[]
  createdAt     DateTime @default(now())

  @@map("salesNTX")
  @@index([transactionDate])
  @@index([customerId])
  @@index([salesmanId])
}

model Sale {
  id            Int      @id @default(autoincrement())
  salesNTXId    Int
  salesNTX      SalesNTX @relation(fields: [salesNTXId], references: [id], onDelete: Restrict)

  // The purchase row this sale line consumed from (FIFO allocation)
  purchaseId    Int?
  purchase      Purchase? @relation(fields: [purchaseId], references: [id], onDelete: Restrict)
  stockMasterId Int?
  stockMaster   StockMaster? @relation(fields: [stockMasterId], references: [id], onDelete: Restrict)

  subcategoryCode String
  carat           String?
  qty             Int
  goldWeight      Decimal
  cost            Decimal
  sellRatePer8g   Decimal @default(0)
  sellCost        Decimal @default(0)

  createdAt DateTime @default(now())

  @@map("sales")
  @@index([salesNTXId])
  @@index([stockMasterId])
  @@index([subcategoryCode])
}

model Salesman {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices  SalesNTX[]

  @@index([name])
  @@index([code])
}

model Purchase {
  id              Int       @id @default(autoincrement())
  purchaseNo      String    @unique
  purchaseDate    DateTime
  purchaseType    String    @default("Gold")
  location        String?
  gsmCode         String?
  gsmName         String?
  categoryCode    String?
  articleName     String?
  subcategoryCode String?
  subcategoryName String?
  qty             Int       @default(0)
  description     String?
  carat           String?
  wastageYN       Boolean   @default(false)
  goldWeight      Decimal   @default(0)
  goldCost        Decimal   @default(0)
  wastageMg       Decimal   @default(0)
  wastage         Decimal   @default(0)
  labourCharges   Decimal   @default(0)
  otherCosts      Decimal   @default(0)
  totalCost       Decimal   @default(0)
  remarks         String?
  supplierId      Int?
  supplier        Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  purchaseGold    String?
  totalItems      Int       @default(0)
  totalWeight     Decimal   @default(0)
  subTotal        Decimal   @default(0)
  otherCharges    Decimal   @default(0)
  totalAmount     Decimal   @default(0)
  paidAmount      Decimal   @default(0)
  balanceDue      Decimal   @default(0)
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  items PurchaseItem[]
  sales Sale[]

  @@map("purchases")
  @@index([purchaseDate])
  @@index([supplierId])
}

model PurchaseItem {
  id              Int      @id @default(autoincrement())
  purchaseId      Int
  purchase        Purchase @relation(fields: [purchaseId], references: [id], onDelete: Restrict)
  description     String
  karat           String?
  weight          Decimal
  ratePerGram     Decimal
  makingPerPiece  Decimal  @default(0)
  amount          Decimal
  createdAt       DateTime @default(now())

  @@map("purchase_items")
  @@index([purchaseId])
}

// NextAuth.js models
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          String    @default("user") // admin, manager, cashier, user
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]

  @@index([email])
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
