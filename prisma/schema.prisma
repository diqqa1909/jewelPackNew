// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model StockMaster {
  id              Int      @id @default(autoincrement())
  transactionDate DateTime
  location        String?

  gsmCode      String
  gsmName      String
  categoryCode String
  articleName  String
  subcategoryCode String
  subcategoryName String
  category     Category @relation(fields: [categoryCode], references: [code], onDelete: Restrict)
  subcategory  Subcategory @relation(fields: [subcategoryCode], references: [code], onDelete: Restrict)
  qty          Int
  description  String?
  carat        String?

  wastageYN     Boolean  @default(false)
  goldWeight    Decimal
  goldCost      Decimal
  wastageMg     Decimal   @default(0)
  wastage       Decimal
  labourCharges Decimal
  otherCosts    Decimal
  totalCost     Decimal
  // Balances (updated as items are sold)
  soldQty          Int     @default(0)
  balanceQty       Int
  soldGoldWeight   Decimal @default(0)
  balanceGoldWeight Decimal
  soldCost         Decimal @default(0)
  balanceCost      Decimal
  remarks       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryCode])
  @@index([subcategoryCode])

  sales Sale[]
}

model Goldsmith {
  code      String   @id
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  code      String   @id
  name      String
  subcategories Subcategory[]
  stock     StockMaster[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subcategory {
  code         String   @id
  name         String
  imageUrl     String?
  categoryCode String
  category     Category @relation(fields: [categoryCode], references: [code], onDelete: Restrict)
  stock        StockMaster[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model System {
  id                   Int     @id
  vatRate              Decimal
  nslRate              Decimal
  goldCostRatePer8g    Decimal
  wastageRateMgPer8g   Decimal
  updatedAt            DateTime @updatedAt

  @@map("system")
}

model Customer {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String?
  email     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sales     SalesNTX[]
}

model SalesNTX {
  id            Int      @id @default(autoincrement())
  saleNo        String   @unique
  transactionDate DateTime
  customerId    Int
  customer      Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)

  totalItems    Int
  totalQty      Int
  totalGoldWeight Decimal
  totalCost     Decimal
  sellRatePer8g Decimal @default(0)
  sellSubTotal  Decimal @default(0)
  remarks       String?

  items         Sale[]
  createdAt     DateTime @default(now())

  @@map("salesNTX")
  @@index([transactionDate])
  @@index([customerId])
}

model Sale {
  id            Int      @id @default(autoincrement())
  salesNTXId    Int
  salesNTX      SalesNTX @relation(fields: [salesNTXId], references: [id], onDelete: Restrict)

  // The receipt row this sale line consumed from (FIFO allocation)
  stockMasterId Int
  stockMaster   StockMaster @relation(fields: [stockMasterId], references: [id], onDelete: Restrict)

  categoryCode    String
  subcategoryCode String
  carat           String?
  qty             Int
  goldWeight      Decimal
  cost            Decimal
  sellRatePer8g   Decimal @default(0)
  sellCost        Decimal @default(0)

  createdAt DateTime @default(now())

  @@map("sales")
  @@index([salesNTXId])
  @@index([stockMasterId])
  @@index([subcategoryCode])
}
